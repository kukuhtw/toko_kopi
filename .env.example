# ============================================================
# Toko Kopi — Environment Configuration
# Salin file ini ke .env dan sesuaikan nilainya.
# JANGAN pernah commit file .env ke version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=toko_kopi
DB_USER=root
DB_PASS=

# ── Aplikasi ─────────────────────────────────────────────────
# development | production
APP_ENV=production

# URL publik tanpa trailing slash
# Contoh lokal : http://localhost/toko_kopi/public
# Contoh prod  : https://yourdomain.com/toko_kopi/public
BASE_URL=https://yourdomain.com/toko_kopi/public

# ── LLM API Keys ─────────────────────────────────────────────
# (Opsional — bisa juga diisi lewat Settings di dashboard)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_IMAGE_MODEL=gpt-image-1-mini
# ANTHROPIC_API_KEY=sk-ant-...
